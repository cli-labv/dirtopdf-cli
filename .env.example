# Configuración de la aplicación Image to PDF CLI
# Copia este archivo a .env y ajusta los valores según tus necesidades

# Contraseña del sistema (para sudo si es necesario)
# IMPORTANTE: Si no quieres ingresar la contraseña cada vez, configúrala aquí
SUDO_PASSWORD=

# Configuración de conversión
PRESERVE_ASPECT_RATIO=true
PDF_QUALITY=95
IMAGE_SORT_METHOD=name  # name, date, size

# Formatos de imagen soportados
SUPPORTED_FORMATS=jpg,jpeg,png,bmp,gif,tiff,tif,webp,jfif

# Procesamiento
MAX_WORKERS=1  # Procesamiento en cola (1 = secuencial)
AUTO_CLEANUP_TEMP=true
KEEP_TEMP_ON_ERROR=false

# Configuración de PDF
PDF_TITLE_FROM_FOLDER=true
PDF_AUTHOR=
PDF_SUBJECT=Converted from images
PDF_CREATOR=Image to PDF CLI

# Límites
MAX_FILE_SIZE_MB=500
MAX_IMAGES_PER_PDF=10000

# UI
SHOW_THUMBNAILS=false
SHOW_DETAILED_PROGRESS=true
BANNER_FONT=slant
BANNER_COLOR=cyan

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=true

# Permisos
AUTO_FIX_PERMISSIONS=true
